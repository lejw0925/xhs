# XHS Flutter API Configuration

# Server Configuration
PORT=8080

# Python Configuration
PYTHON_PATH=python3
XHS_MODULE_PATH=../

# XHS Cookie (Required for API functionality)
# Get this from your browser when logged into xiaohongshu.com
XHS_COOKIE=your_xiaohongshu_cookie_here

# Optional: Test Configuration
# These are used by the test script
XHS_NOTE_ID=sample_note_id
XHS_XSEC_TOKEN=sample_xsec_token
XHS_USER_ID=sample_user_id
XHS_SEARCH_KEYWORD=美食